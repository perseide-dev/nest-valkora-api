# --- APP CONFIGURATION ---
NODE_ENV=development
PORT=3000

# --- DATABASE (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=pedbox_db

# --- AUTHENTICATION ---
# Genera un string aleatorio fuerte para el JWT
JWT_SECRET=super_secret_random_string_2026
# Esta es la Key que el sistema validará en el ApiKeyGuard
API_KEY_SYSTEM=internal_master_key_for_dev

# --- COOKIE CONFIGURATION ---
# (Opcional si decides parametrizar el dominio o seguridad de la cookie)
COOKIE_DOMAIN=localhost